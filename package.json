{
  "name": "JournalBear",
  "repository": "https://github.com/yrahul3910/journal",
  "description": "Easy-to-use journaling application",
  "author": {
    "name": "Rahul Yedida",
    "email": "yrahul3910@gmail.com"
  },
  "build": {
    "appId": "com.yrahul.journal",
    "linux": {
      "target": [
        "rpm"
      ],
      "icon": "./icons",
      "category": "Office"
    },
    "mac": {
      "target": "dir",
      "icon": "./icons/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "./icons/icon.ico"
    }
  },
  "version": "7.0.0",
  "type": "module",
  "main": "out/main/index.js",
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@tailwindcss/typography": "^0.5.20",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "electron-vite": "^5.0.0",
    "lucide-react": "^0.563.0",
    "owasp-password-strength-test": "^1.3.0",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.1.3",
    "showdown": "^2.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tar": "^7.5.19",
    "typescript": "^7.0.2",
    "vite": "^8.1.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.0",
    "@types/owasp-password-strength-test": "^1.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/showdown": "^2.0.6",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "3.4.17",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "postinstall": "install-electron && electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron app/index.js",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist-mac": "npm run build && electron-builder -m --arm64",
    "dist-linux": "npm run build && electron-builder -l",
    "dist-win": "npm run build && electron-builder -w --x64",
    "ship": "npm run build && electron-builder -p always",
    "check": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
