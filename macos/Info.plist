<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Merged into the generated Info.plist (GENERATE_INFOPLIST_FILE stays on).
	     Declares the .zjournal type so the file pickers on both platforms
	     resolve it to a stable identity instead of a dynamic type. -->
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.yrahul.journalbear.zjournal</string>
			<key>UTTypeDescription</key>
			<string>JournalBear Journal</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>zjournal</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
